{
  "name": "logion-app",
  "version": "1.0.0",
  "author": "Jacob Murel",
  "license": "MIT",
  "description": "A machine learning tool for Greek philology",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac --x64",
    "dev": "concurrently \"npm run start\" \"cd ../backend && source logion-venv/bin/activate && python3 main.py\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-log": "^5.2.4"
  },
  "build": {
    "appId": "logion",
    "productName": "Logion",
    "files": [
      "main.js",
      "loading.html",
      "frontend/**/*",
      "!../backend/logion-venv/**/*"
    ],
    "extraResources": [
      "./extraResources/"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icons/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icons/icon.png"
    }
  }
}
